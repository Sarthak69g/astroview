# Public client-side environment variables (safe to expose in the browser)
# Copy these into a .env.local file and fill in your EmailJS credentials.

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Server-only secret (no VITE_ prefix — never exposed to the browser).
# Get this from your AstrologyAPI.com dashboard > API Credentials >
# Access Token tab (the recommended, non-Basic-Auth method).
ASTROLOGYAPI_ACCESS_TOKEN=your_access_token_here



PROKERALA_CLIENT_ID=<client id>
PROKERALA_CLIENT_SECRET=<client secret>